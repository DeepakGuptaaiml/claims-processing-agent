# Downstream ML APIs (medicare_classifier + claims-intelligence)
MEDICARE_API_URL=http://127.0.0.1:8000
RESERVE_API_URL=http://127.0.0.1:8001

# Azure (set automatically by CD deploy workflow)
# MEDICARE_API_URL=https://medicare-classifier-api.<fqdn>
# RESERVE_API_URL=https://claims-reserve-api.<fqdn>

# Claim history store
STORE_BACKEND=sqlite
SQLITE_DB_PATH=mcp_server/data/claims_ai.db

# Oracle prod (CLAIMS_AI_RO read-only user)
# STORE_BACKEND=oracle
# ORACLE_DSN=hostname:1521/CLAIMSDB
# ORACLE_USER=CLAIMS_AI_RO
# ORACLE_PASSWORD=

# CSV for seeding claim store (local dev; Docker uses data/claims_data.csv)
# CLAIMS_CSV_PATH=data/claims_data.csv
