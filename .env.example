# Downstream ML APIs (medicare_classifier + claims-intelligence)
MEDICARE_API_URL=http://127.0.0.1:8000
RESERVE_API_URL=http://127.0.0.1:8001

# Claim history store: sqlite (dev) | oracle (prod)
STORE_BACKEND=sqlite
SQLITE_DB_PATH=mcp_server/data/claims_ai.db

# Oracle prod (CLAIMS_AI_RO read-only user — not used in dev)
# ORACLE_DSN=hostname:1521/CLAIMSDB
# ORACLE_USER=CLAIMS_AI_RO
# ORACLE_PASSWORD=

# CSV for seeding SQLite (defaults to sibling medicare_classifier repo)
# CLAIMS_CSV_PATH=../medicare_classifier/data/claims_data.csv
